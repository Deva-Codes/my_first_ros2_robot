<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
      
   <xacro:include filename="$(find my_package)/urdf/my_robot.gazebo" />
    <link name = "base_footprint"/>
    <joint name = "base_footprint_base" type = "fixed">
        <parent link = "base_footprint"/>
        <child link = "base_link"/>
        <origin xyz = "0 0 .4"/>
    </joint>
    
    <link name="base_link">
        <visual>
            <geometry><box size="1.0 0.75 .4"/></geometry>
        </visual>
        <collision>
            <geometry><box size="1.0 0.75 0.4"/></geometry>
        </collision>
        <inertial>
            <mass value="10.0"/>
            <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.5"/>
        </inertial>
    </link>

    <link name="left_wheel">
        <visual>
            <origin rpy="-1.57 0 0"/>
            <geometry><cylinder radius="0.2" length="0.1"/></geometry>
        </visual>
        <collision>
            <origin rpy="-1.57 0 0"/>
            <geometry><cylinder radius="0.2" length="0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
        </inertial>
    </link>
    
    <gazebo reference="left_wheel">
        <mu1>10.0</mu1>
        <mu2>10.0</mu2>
    </gazebo>

    <joint name="base_left_wheel" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="-.25 .43 -.2"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <origin rpy="1.57 0 0"/>
            <geometry><cylinder radius="0.2" length="0.1"/></geometry>
        </visual>
        <collision>
            <origin rpy="1.57 0 0"/>
            <geometry><cylinder radius="0.2" length="0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
        </inertial>
    </link>

    <gazebo reference="right_wheel">
        <mu1>10.0</mu1>
        <mu2>10.0</mu2>
    </gazebo>

    <joint name="base_right_wheel" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="-.25 -.43 -.2"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <link name="castor_wheel">
        <visual>
            <geometry><sphere radius="0.1"/></geometry>
        </visual>
        <collision>
            <geometry><sphere radius="0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
        </inertial>
    </link>

    <gazebo reference="castor_wheel">
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>

    <joint name="base_castor_wheel" type="fixed">
        <parent link="base_link"/>
        <child link="castor_wheel"/>
        <origin xyz=".5 0 -.3"/>
    </joint>

    <gazebo reference="left_wheel">
  <material>Gazebo/Blue</material>
</gazebo>

<gazebo reference="right_wheel">
  <material>Gazebo/Blue</material>
</gazebo>
<gazebo reference="base_link">
  <material>Gazebo/Red</material>

</gazebo>
<gazebo reference="castor_wheel">
  <material>Gazebo/Blue</material>
</gazebo>

<link name = "camera_link">
    <pose>0 0 0 0 0 0</pose>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
          ixx="1e-6" ixy="0" ixz="0"
          iyy="1e-6" iyz="0"
          izz="1e-6"
      />
    </inertial>
    <visual>
        <origin xyz = "0 0 0" rpy = "0 0 0"/>
        <geometry>
            <box size = ".03 .03 .03"/>
        </geometry>
    </visual>
    <collision>
        <origin xyz = "0 0 0" rpy = "0 0 0"/>
        <geometry>
            <box size = ".03 .03 .03"/>
        </geometry>
    </collision>
    <gazebo reference="camera_link">
    <material>Gazebo/Red</material>
  </gazebo>

</link>
<joint name = "base_camera" type = "fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz = "0 0 .7" rpy = "0 0.1745 0"/>
</joint>
<link name = "camera_optical"/>
<joint name = "camera_optical_camera" type = "fixed">
    <parent link="camera_link"/>
    <child link="camera_optical"/>
    <origin xyz = "0 0 0" rpy = "-1.57 0 -1.57"/>
    
</joint>

<link name = "imu_link" />
<joint name = "base_imu" type = "fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz = "0 0 0" rpy = "0 0 0"/>
    
    </joint>

    <link name = "navsat_link"/>
    <joint name = "base_navsat" type = "fixed">
        <parent link="base_link"/>
        <child link="navsat_link"/>
        <origin xyz = "0 0 0" rpy = "0 0 0"/>
        
    </joint>

    


    
</robot>