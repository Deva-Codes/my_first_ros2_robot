<?xml version="1.0"?>
<robot name="my_first_robot">
    
    <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
    </material>
    <material name="blue">
        <color rgba="0 0 0.8 1"/>
    </material>

   <link name="base_footprint"/>
<joint name="basefootprint_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.45" rpy="0 0 0"/>
</joint>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="1 0.5 0.5"/>           
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="1 0.5 0.5"/>           
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="10.0"/>
            <inertia ixx="0.416" ixy="0.0" ixz="0.0" iyy="1.041" iyz="0.0" izz="1.041"/>
        </inertial>
    </link>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.1"/>
            </geometry>
            <origin rpy="1.5705 0 0"/>
            <material name="grey"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.1"/>
            </geometry>
            <origin rpy="1.5705 0 0"/>
        </collision>
        <inertial>
            <origin rpy="1.5705 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.0108" ixy="0.0" ixz="0.0" iyy="0.0108" iyz="0.0" izz="0.02"/>
        </inertial>
    </link>
    
    <joint name="leftwheel_base" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="-0.25 -0.32 -0.25"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.1"/>
            </geometry>
            <origin rpy="-1.5705 0 0"/>
            <material name="grey"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.2" length="0.1"/>
            </geometry>
            <origin rpy="-1.5705 0 0"/>
        </collision>
        <inertial>
            <origin rpy="-1.5705 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.0108" ixy="0.0" ixz="0.0" iyy="0.0108" iyz="0.0" izz="0.02"/>
        </inertial>
    </link>
    
    <joint name="right_wheel_base" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="-0.25 0.32 -0.25"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <link name="castor_wheel">
        <visual>
            <geometry>
                <sphere radius="0.1"/>
            </geometry>
            <material name="grey"/>          
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.5"/>
            <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
        </inertial>
    </link>
    
    <joint name="castorwheel_base_link" type="fixed">
        <parent link="base_link"/>
        <child link="castor_wheel"/>
        <origin xyz="0.25 0 -0.35"/>
    </joint>
   
    
</robot>