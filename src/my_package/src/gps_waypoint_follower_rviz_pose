import math
import rclpy 
from rclpy.node import Node
from sensor_msgs.msg import  NavSatFix, Imu
from geometry_msgs.msg import Twist, PoseStamped


class gps_waypoint_follower(Node):
    def __init__(self):
        super().__init__("gps_waypoint_follower")
        self.origin_lat = 0.0
        self.origin_lon = 0.0

        self.current_lat = None
        self.current_lon = None
        self.current_yaw = None

        self.goal_x = None
        self.goal_y = None

        self.create_subscription(NavSatFix,'/navsat',self.gps_callback,10)
        self.create_subscription(Imu,'/imu',self.imu_callback,10)
        self.create_subscription(PoseStamped,'/goal_pose',self.goal_callback,10)
        self.publisher = self.create_publisher(Twist,'/cmd_vel',10)

        self.timer = self.create_timer(0.1,self.control_loop)
        self.get_logger().info("gps_waypoint_navigator_started")

    def gps_callback(self,msg):
        self.current_lat = msg.latitude
        self.current_lon = msg.longitude
    def imu_callback(self,msg):
         q = msg.orientation
         siny_cosp = 2 * (q.w * q.z + q.x * q.y)
         cosy_cosp = 1 - 2 * (q.y * q.y + q.z * q.z)
         self.current_yaw = math.atan2(siny_cosp, cosy_cosp)
    def goal_callback(self,msg):
        self.goal_x = msg.pose.position.x
        self.goal_y = msg.pose.position.y
        self.get_logger().info(f'new goal received : x= {self.goal_x} y= {self.goal_y}')
    def gps_to_local(self):
        delta_lat = self.current_lat-self.origin_lat
        delta_lon  = self.current_lon-self.origin_lon
        local_x = delta_lon * 111320 * math.cos(math.radians(self.origin_lat))
        local_y = delta_lat * 111320
        return local_x,local_y
    def control_loop(self):
        if self.current_lat is None or self.current_yaw is None:
            return
        if self.goal_x is None:
            print("waiting for the target goal")
            return
        cmd = Twist()
        current_x , current_y = self.gps_to_local()
        dx = self.goal_x - current_x
        dy = self.goal_y - current_y

        distance = math.sqrt(dx**2 + dy**2)
        bearing = math.atan2(dy, dx) 

        heading_error = bearing - self.current_yaw
        heading_error = math.atan2(math.sin(heading_error), math.cos(heading_error))
        
        if distance < 1.0:
            cmd.linear.x = 0.0
            cmd.angular.z = 0.0
            self.get_logger().info('Waypoint reached!')
            self.goal_x = None  # clear goal so it stops and waits for next click
        else:
            cmd.linear.x = 0.5
            cmd.angular.z = 1.0 * heading_error
            self.get_logger().info(
                f'dist={distance:.2f}m err={math.degrees(heading_error):.1f}deg '
                f'pos=({current_x:.1f},{current_y:.1f}), target is ({self.goal_x,self.goal_y})')

        self.publisher.publish(cmd)
def main():
    rclpy.init()
    node  = gps_waypoint_follower()
    rclpy.spin(node)
    rclpy.shutdown()

if __name__ == "__main__":
    main()
